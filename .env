# =============================================================================
# Environment variables template (COMMITTED to the repo)
# -----------------------------------------------------------------------------
# This file is only a reference: it lists the expected variables WITHOUT any
# sensitive values. The real values (credentials, secrets) go in .env.local,
# which is gitignored.
#
# Next.js load order: .env  ->  .env.local (override).
# On the Prisma CLI side, .env.local is loaded via prisma.config.ts.
# =============================================================================

# PostgreSQL (Neon) connection URL — POOLED endpoint (host has "-pooler").
# Real value goes in .env.local (dev) / Vercel env (prod):
# postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=
# DIRECT (unpooled) Neon URL — same host WITHOUT "-pooler". Used by the Prisma
# CLI for migrations only (advisory locks time out through the pooler → P1002).
# The Neon Vercel integration usually provides it; add it to .env.local too.
# DATABASE_URL_UNPOOLED=

# App version = current git tag. Not secret, committed here.
# Updated automatically as the preamble of every preview-release
# (see the preview-release skill) to the tag about to be created.
APP_RELEASE=v0.3.10

# Maintenance mode (proxy.ts): a truthy value (true/1/on/yes, case/space
# insensitive) => the site returns a 503 "En construction" page. Enable ONLY on
# Vercel Production (off in Preview/local). Toggling requires a Vercel redeploy.
APP_MAINTENANCE=

# Maintenance-mode bypass secret: visiting ...?unlock=<secret> sets a cookie that
# lets you see the real site despite maintenance. Real value in .env.local /
# Vercel env (Production), never committed.
APP_MAINTENANCE_BYPASS=

# Media storage — Cloudinary (see lib/media.ts). Used to upload recipe photos.
# Put the real values in .env.local (never commit them). When unset, the app
# falls back to gradient placeholders and the upload is disabled.
# Find these in your Cloudinary dashboard (Account Details).
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Optional: target folder for uploads (defaults to "recipe-manager").
# CLOUDINARY_FOLDER=recipe-manager

# Seasonal calendar — Pexels images (server-only). Real value in .env.local /
# Vercel env. Unset → warm gradient placeholders, no image fetch.
# PEXELS_API_KEY=

# Gemini API key — recipe photo scan (server-only, lib/gemini.ts). Real value in
# .env.local / Vercel env. Can be overridden at runtime by the key saved from
# /parametres/general (Setting table). Unset → the photo-scan creation method is
# disabled. GEMINI_MODEL (optional) overrides the model id (default gemini-2.5-flash).
# GEMINI_API_KEY=
# GEMINI_MODEL=


# Cron secret for the scheduled seasonal-data update (/api/cron/season-update).
# Vercel Cron sends it as "Authorization: Bearer <value>". Set the real value in
# Vercel env (Production). Unset → the cron route is a safe no-op (401); the
# manual "Mettre à jour" button still works.
# CRON_SECRET=
