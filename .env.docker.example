# =============================================================================
# Docker / VPS environment — copy to .env and fill in real values
# =============================================================================
# DATABASE_URL is built automatically by docker-compose from POSTGRES_* vars;
# you do NOT need to set it here. Only set it if you point to an external DB.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB

# ── Postgres (docker-compose managed) ────────────────────────────────────────
POSTGRES_DB=mealoday
POSTGRES_USER=mealoday
POSTGRES_PASSWORD=change_me_strong_password

# ── App ───────────────────────────────────────────────────────────────────────
# Current app version (shown in footer / health endpoint)
APP_RELEASE=v0.4.0

# Maintenance mode: truthy (true/1/on/yes) → 503 "En construction" page
APP_MAINTENANCE=

# Visiting ?unlock=<secret> bypasses maintenance mode (cookie-based)
APP_MAINTENANCE_BYPASS=

# Port exposed on the host (default 3000)
PORT=3000

# ── Cloudinary — recipe photo uploads ────────────────────────────────────────
# Find these in your Cloudinary dashboard → Account Details
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Target folder for uploads (optional, defaults to "mealoday")
CLOUDINARY_FOLDER=mealoday

# ── Pexels — seasonal produce thumbnails ─────────────────────────────────────
# Unset → warm gradient placeholders, no image fetch
PEXELS_API_KEY=

# ── Gemini — recipe photo scan ───────────────────────────────────────────────
# Unset → photo-scan creation method is disabled
GEMINI_API_KEY=
# Override the model id (optional; default: gemini-2.5-flash)
GEMINI_MODEL=

# ── Cron ─────────────────────────────────────────────────────────────────────
# Bearer token for /api/cron/season-update. Unset → route is a safe no-op (401)
CRON_SECRET=
