# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
# .env = template commité (nomenclature, sans secret)
# .env.local et variantes locales = secrets, jamais commités
.env*
!.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# claude code : outillage local, jamais versionné (skills, réglages, etc.)
.claude/

# dossier de travail design (copier-coller depuis Claude design), non versionné
.design/

# backlog de travail local, non versionné
BACKLOG.md
