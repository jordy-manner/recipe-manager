// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// How a recipe's "in season" months are determined.
enum SeasonMode {
  AUTO // derived from the primary ingredients' seasons
  MANUAL // explicit month list (seasonMonths)
  ALWAYS // available all year round
}

model Recipe {
  id          String   @id @default(cuid())
  slug        String   @unique // URL-friendly identifier derived from the title
  title       String
  description String?
  servings    Int?
  prepTime    Int? // minutes
  cookTime    Int? // minutes
  restTime    Int? // minutes (resting/proofing time)
  difficulty  Int? // 1 = easy, 2 = medium, 3 = hard
  rating      Float? // average rating out of 5
  author      String?
  popular     Boolean  @default(false) // featured in the "popular" section
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Seasonality: how the recipe's active months are computed. In MANUAL mode,
  // seasonMonths holds the active months (1–12); ignored for AUTO/ALWAYS.
  seasonMode   SeasonMode @default(AUTO)
  seasonMonths Int[]      @default([])

  // Nutrition facts, per serving (all optional).
  kcal    Int?
  protein Int? // grams
  carbs   Int? // grams
  fat     Int? // grams

  // Recipe photo. The image bytes live with the media provider (Cloudinary for
  // now, see lib/media.ts); we only store the public URL + the provider id
  // needed to delete it. Designed to swap to local storage later.
  imageUrl      String?
  imagePublicId String?

  // Ingredients of the recipe (many-to-many via the explicit RecipeIngredient
  // join, which carries the quantity and the unit).
  recipeIngredients RecipeIngredient[]
  // Utensils of the recipe (many-to-many via the explicit RecipeUtensil join,
  // which carries the quantity).
  recipeUtensils    RecipeUtensil[]
  // Shared tags (many-to-many via the explicit RecipeTag join table).
  recipeTags        RecipeTag[]
  // Categories of the recipe (many-to-many via the explicit RecipeCategory
  // join). A recipe can belong to several categories.
  recipeCategories  RecipeCategory[]
  // Ordered preparation steps (own table rather than a Json column).
  recipeSteps       Step[]
}

// A single ordered preparation step of a recipe (Markdown content).
model Step {
  id       String @id @default(cuid())
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String
  content  String
  order    Int    @default(0) // display order within the recipe

  @@index([recipeId])
}

// Seasonal-produce category. An ingredient with a category is shown on /saisons.
// Values are unaccented (Prisma enum identifiers); the UI maps them to French.
enum ProduceCategory {
  fruits
  legumes
  herbes
  legumineuses
}

// Catalog of reusable ingredients (e.g. "farine", "œuf"). Unique name.
// An ingredient that is also a seasonal produce carries optional season fields:
// when `category` is set it appears on /saisons (slug = URL key, months 1–12,
// ecv = ADEME Agribalyse carbon footprint kg CO2e/kg). Editable from the app.
model Ingredient {
  id                String             @id @default(cuid())
  name              String             @unique
  recipeIngredients RecipeIngredient[]

  // Catalog metadata (edited from /parametres). `aisle` is the grocery aisle
  // ("rayon", e.g. "Légume", "Épicerie"), an editable referential (model Aisle).
  // `defaultUnit` pre-fills the unit when the ingredient is added to a recipe.
  // Both null => the entry shows as "À compléter".
  aisleId       String?
  aisle         Aisle?  @relation(fields: [aisleId], references: [id], onDelete: SetNull)
  defaultUnitId String?
  defaultUnit   Unit?   @relation("IngredientDefaultUnit", fields: [defaultUnitId], references: [id], onDelete: SetNull)

  // Optional custom image (priority over the auto Pexels thumbnail). The bytes
  // live with the media provider; we only store the URL + the id to delete it.
  image         String?
  imagePublicId String?

  // Seasonality (null/empty for non-produce ingredients like salt, flour).
  slug            String?          @unique
  category        ProduceCategory?
  months          Int[]            @default([])
  ecv             Float? // kg CO2e / kg
  ecvSource       String? // "agribalyse" | "manual"
  seasonUpdatedAt DateTime?

  @@index([category])
  @@index([defaultUnitId])
  @@index([aisleId])
}

// Editable referential of grocery aisles ("rayons", e.g. "Légume", "Épicerie").
// Classifies ingredients; usage = number of ingredients in the aisle. Renaming
// follows the id (the ingredient relation is unchanged). Managed from
// /parametres/rayons.
model Aisle {
  id          String       @id @default(cuid())
  name        String       @unique
  ingredients Ingredient[]
}

// Catalog of reusable units of measure (e.g. "g", "kg", "ml", "pincée", "unité").
model Unit {
  id                String             @id @default(cuid())
  name              String             @unique
  recipeIngredients RecipeIngredient[]

  // Catalog metadata (edited from /parametres). `abbreviation` is the short
  // form shown in recipes ("g", "c. à s."); `type` is the unit family (Masse,
  // Volume…), an editable referential (model UnitType). Either null => the
  // entry shows as "À compléter".
  abbreviation String?
  typeId       String?
  type         UnitType? @relation(fields: [typeId], references: [id], onDelete: SetNull)

  // Ingredients that use this unit as their default (inverse of
  // Ingredient.defaultUnit).
  defaultForIngredients Ingredient[] @relation("IngredientDefaultUnit")

  @@index([typeId])
}

// Editable referential of unit families ("types d'unité": Masse, Volume…).
// Groups units; usage = number of units of the type. Managed from
// /parametres/types-unite.
model UnitType {
  id    String @id @default(cuid())
  name  String @unique
  units Unit[]
}

// Explicit Recipe <-> Ingredient join, carrying the quantity and the unit.
// Table "RecipeIngredient" (columns recipeId / ingredientId, composite PK).
model RecipeIngredient {
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId     String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  ingredientId String
  quantity     Float? // e.g. 250, 0.5, 3 — optional ("sel à volonté")
  unit         Unit?      @relation(fields: [unitId], references: [id], onDelete: SetNull)
  unitId       String?
  position     Int        @default(0) // display order within the recipe
  // Marks a "main" ingredient, used for AUTO seasonality detection.
  isPrimary    Boolean    @default(false)

  @@id([recipeId, ingredientId])
  @@index([ingredientId])
  @@index([unitId])
}

// Catalog of reusable utensils (e.g. "cuillère en bois", "moule à manqué
// 24 cm", "poêle 28 cm"). Unique name. Size variants (diameter) are distinct
// catalog entries.
model Utensil {
  id             String          @id @default(cuid())
  name           String          @unique
  recipeUtensils RecipeUtensil[]

  // Optional custom image (priority over the auto Pexels thumbnail). The bytes
  // live with the media provider; we only store the URL + the id to delete it.
  image         String?
  imagePublicId String?
}

// Explicit Recipe <-> Utensil join, carrying the quantity (number of utensils).
// Table "RecipeUtensil" (columns recipeId / utensilId, composite PK).
model RecipeUtensil {
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId  String
  utensil   Utensil @relation(fields: [utensilId], references: [id], onDelete: Cascade)
  utensilId String
  quantity  Int? // e.g. 1, 2 — optional (defaults to 1 when displayed)
  position  Int     @default(0) // display order within the recipe

  @@id([recipeId, utensilId])
  @@index([utensilId])
}

// Catalog of recipe categories (e.g. "Plat de résistance", "Dessert"). Unique
// name. Shared across recipes via the explicit RecipeCategory join.
model Category {
  id               String           @id @default(cuid())
  name             String           @unique
  recipeCategories RecipeCategory[]
}

// Explicit join table for the many-to-many Recipe <-> Category relation.
// Table "RecipeCategory" (columns recipeId / categoryId, composite PK).
model RecipeCategory {
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId   String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String
  position   Int      @default(0) // display order within the recipe

  @@id([recipeId, categoryId])
  @@index([categoryId])
}

// A tag is reusable and shared across multiple recipes.
model Tag {
  id         String      @id @default(cuid())
  name       String      @unique
  recipeTags RecipeTag[]
}

// Explicit join table for the many-to-many Recipe <-> Tag relation.
// Table: "RecipeTag", columns: "recipeId" and "tagId" (composite primary key).
model RecipeTag {
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId    String

  @@id([recipeId, tagId])
  @@index([tagId])
}

// Server-side key/value settings edited from /parametres (e.g. the Pexels API
// key, the seasonal-data check frequency + last-check date). Secrets live here,
// read server-side only and never sent to the client. Theme/accent are NOT
// stored here — they are a client preference (localStorage).
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
